    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a Master Content Strategist and an Elite AI Automation Architect.\n\nHere is the structured information from our Researcher:\n{{ $json.output }}\n\nYour Task:\n1. MUST query the Qdrant tool to retrieve the specific engineering tone, vocabulary, and personal branding style.\n2. Turn the Researcher's information into a high-converting LinkedIn post.\n\nWriting Strategy & Tone:\n- ROI First: Focus on how this automation saves time and money for businesses.\n- Beginner-Friendly: Explain the tech simply.\n- The Connector: Write like a partner offering a high-value solution to clients. Position the author as the expert who builds n8n and learns about AI agents.\n\nCRITICAL OUTPUT RULES:\n- Start DIRECTLY with: TITLE: [Your Engaging Title]\n- Use natural line breaks, bold headings, and professional emojis as least as possible\n- Do NOT write \"Here is the post\" or any intro/outro.\n- End with a Call To Action (CTA) inviting them to connect for automation builds.",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [ 320, 688 ],
      "id": "cb2d2d49-8c39-4006-abec-466b788d347b",
      "name": "Content Writer Agent",
      "retryOnFail": true,
      "waitBetweenTries": 5000
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.item.json.output || '';\n\nlet clean = raw\n  .replace(/^.*?here['']?s the post[:\\s]*/i, '')\n  .replace(/^based on[^.\\n]*[.\\n]*/i, '')\n  .replace(/^I can now write[^.\\n]*[.\\n]*/i, '')\n  .replace(/[*_\\[\\]`]/g, '') \n  .replace(/\\n{3,}/g, '\\n\\n')\n  .trim();\n\nlet extractedTitle = \"New LinkedIn Post\"; \nlet extractedContent = clean;\n\nconst titleRegex = /^TITLE:\\s*(.*)/i;\nconst match = clean.match(titleRegex);\n\nif (match) {\n  extractedTitle = match[1].trim(); \n  extractedContent = clean.replace(titleRegex, '').trim(); \n}\n\nreturn { \n  json: { \n    full_post: clean, \n    title: extractedTitle, \n    content: extractedContent \n  } \n};"
      },
