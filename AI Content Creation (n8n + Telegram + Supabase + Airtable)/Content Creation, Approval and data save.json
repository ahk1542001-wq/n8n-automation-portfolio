      "position": [ 288, 912 ],
      "id": "b3a5e1b6-52a8-4a93-a31e-69884eeea7d0",
      "name": "OpenAI Chat Model",
      "credentials": {
        "openAiApi": {
          "id": "YOUR_OPENAI_CRED_ID",
          "name": "OpenAi account"
