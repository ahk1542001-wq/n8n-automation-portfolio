    {
      "parameters": {
        "jsCode": "// Parse AI Agent output \u2192 extract match_score, reason, customer reply\nconst rawOutput = $node[\"AI Agent1\"].json.output || \"\";\n\nlet matchScore = 0;\nlet reasonText = \"Evaluation failed.\";\nlet customerAnswer = rawOutput;\n\n// Step 1: Extract <lead_data> XML block\nconst xmlRegex = /<lead_data>([\\s\\S]*?)<\\/lead_data>/i;\nconst xmlMatch = rawOutput.match(xmlRegex);\n\nif (xmlMatch && xmlMatch[1]) {\n  try {\n    const leadData = JSON.parse(xmlMatch[1].trim());\n    matchScore = parseInt(leadData.match_score || 0);\n    reasonText = leadData.reason || \"Evaluated.\";\n    customerAnswer = rawOutput.replace(xmlRegex, \"\").trim();\n  } catch (e) {\n    reasonText = \"Error: Invalid JSON format in lead_data.\";\n  }\n} else {\n  reasonText = \"Error: Missing lead_data block.\";\n}\n\n// Step 2: Strip AI monologue prefixes\nconst monologueRegex = /^(okay|wait|let's see|analysis|thinking|hmm)[\\s\\S]*?(\"?Hello|\"?Hi|\"?Dear|\u1019\u1004\u103a\u1039\u1002\u101c\u102c\u1015\u102b)/i;\nconst monologueMatch = customerAnswer.match(monologueRegex);\nif (monologueMatch) {\n  const startIndex = customerAnswer.search(/(\"?Hello|\"?Hi|\"?Dear|\u1019\u1004\u103a\u1039\u1002\u101c\u102c\u1015\u102b)/i);\n  if (startIndex !== -1) {\n    customerAnswer = customerAnswer.substring(startIndex).replace(/^\"|\"$/g, '').trim();\n  }\n}\n\n// BUG FIX 1: Sanitize ALL text sent to Telegram to prevent HTML entity parse errors\n// Replaces < > & which break Telegram's HTML parser\nfunction sanitize(text) {\n  return String(text)\n    .replace(/&/g, 'and')\n    .replace(/</g, '(')\n    .replace(/>/g, ')')\n    .replace(/[*_`#]/g, '')\n    .trim();\n}\n\nreturn {\n  json: {\n    customer_answer: sanitize(customerAnswer),\n    match_score: matchScore,\n    reason: sanitize(reasonText),\n    lead_name: $node[\"Webhook1\"].json.body.name || \"Customer\",\n    lead_email: $node[\"Webhook1\"].json.body.email || \"\",\n    lead_budget: $node[\"Webhook1\"].json.body.budget_usd || \"\",\n    lead_needs: $node[\"Webhook1\"].json.body.needs || \"\"\n  }\n};"
      },
